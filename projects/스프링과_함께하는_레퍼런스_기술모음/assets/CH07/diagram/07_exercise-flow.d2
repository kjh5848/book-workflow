direction: right

classes: {
  step: {
    shape: rectangle
    style: {
      fill: "#ffffff"
      stroke: "#2563eb"
      stroke-width: 2
      border-radius: 8
      shadow: true
      font-size: 20
      font-color: "#374151"
      bold: true
    }
    width: 220
    height: 70
  }
}

step1: "영상 업로드\nAPI 구현" {
  class: step
}
step2: "FFmpeg\n인코딩" {
  class: step
}
step3: "m3u8 + ts\n파일 생성" {
  class: step
}
step4: "브라우저\nHLS.js 재생" {
  class: step
}

step1 -> step2: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
step2 -> step3: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
step3 -> step4: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
