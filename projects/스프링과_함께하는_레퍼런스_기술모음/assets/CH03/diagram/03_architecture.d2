direction: right

classes: {
  start-end: {
    shape: oval
    style: {
      fill: "#ffffff"
      stroke: "#c5cee0"
      stroke-width: 2
      shadow: true
      font-size: 18
      font-color: "#374151"
    }
    width: 150
    height: 70
  }
  process: {
    shape: rectangle
    style: {
      fill: "#eef2ff"
      font-color: "#1e40af"
      stroke: "#2563eb"
      stroke-width: 2
      border-radius: 8
      shadow: true
      font-size: 18
      bold: true
    }
    width: 150
    height: 60
  }
  storage: {
    shape: cylinder
    style: {
      fill: "#f8fafc"
      stroke: "#c5cee0"
      stroke-width: 2
      shadow: true
      font-size: 18
      font-color: "#374151"
      bold: true
    }
    width: 140
    height: 80
  }
  group-box: {
    style: {
      stroke: "#2563eb"
      stroke-width: 2
      stroke-dash: 5
      fill: "#ffffff"
      font-size: 22
      bold: true
      font-color: "#1e3a5f"
    }
  }
}

client: Client {
  class: start-end
}
nginx: "Nginx\n리버스 프록시" {
  class: process
}

servers: Spring 서버 {
  class: group-box
  direction: right

  appA: "Spring A\n/app1" {
    class: process
  }
  appB: "Spring B\n/app2" {
    class: process
  }
}

redis: "Redis\n세션 저장소" {
  class: storage
}

client -> nginx: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
nginx -> servers.appA: /app1 {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
nginx -> servers.appB: /app2 {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
servers.appA -> redis: "세션 읽기/쓰기" {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
servers.appB -> redis: "세션 읽기/쓰기" {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
