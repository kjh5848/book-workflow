direction: right

classes: {
  step: {
    shape: rectangle
    style: {
      fill: "#ffffff"
      stroke: "#2563eb"
      stroke-width: 2
      border-radius: 8
      shadow: true
      font-size: 20
      font-color: "#374151"
      bold: true
    }
    width: 220
    height: 70
  }
}

step1: "Dockerfile 작성\n+ entrypoint.sh" {
  class: step
}
step2: "docker-compose\nup" {
  class: step
}
step3: "Spring Boot\n서버 실행" {
  class: step
}
step4: "브라우저\nlocalhost:8080" {
  class: step
}

step1 -> step2: {
  style: {
    stroke: "#2563eb"
    stroke-width: 2
  }
}
step2 -> step3: {
  style: {
    stroke: "#2563eb"
    stroke-width: 2
  }
}
step3 -> step4: {
  style: {
    stroke: "#2563eb"
    stroke-width: 2
  }
}
