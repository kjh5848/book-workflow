direction: right

classes: {
  step: {
    shape: rectangle
    style: {
      fill: "#ffffff"
      stroke: "#2563eb"
      stroke-width: 2
      border-radius: 8
      shadow: true
      font-size: 20
      font-color: "#374151"
      bold: true
    }
    width: 220
    height: 70
  }
}

step1: "Docker\nES + Kibana" {
  class: step
}
step2: "데이터 저장\nRDB + ES" {
  class: step
}
step3: "ES 검색\n→ RDB 재조회" {
  class: step
}
step4: "Fuzzy 검색\nKibana 실습" {
  class: step
}

step1 -> step2: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
step2 -> step3: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
step3 -> step4: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
