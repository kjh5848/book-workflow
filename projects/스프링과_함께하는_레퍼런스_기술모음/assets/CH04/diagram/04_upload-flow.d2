direction: right

classes: {
  start-end: {
    shape: oval
    style: {
      fill: "#ffffff"
      stroke: "#c5cee0"
      stroke-width: 2
      shadow: true
      font-size: 18
      font-color: "#374151"
    }
    width: 160
    height: 70
  }
  process: {
    shape: rectangle
    style: {
      fill: "#eef2ff"
      font-color: "#1e40af"
      stroke: "#2563eb"
      stroke-width: 2
      border-radius: 8
      shadow: true
      font-size: 18
      bold: true
    }
    width: 160
    height: 60
  }
  storage: {
    shape: cylinder
    style: {
      fill: "#f8fafc"
      stroke: "#c5cee0"
      stroke-width: 2
      shadow: true
      font-size: 18
      font-color: "#374151"
      bold: true
    }
    width: 140
    height: 80
  }
}

client: "Client\nBase64 문자열" {
  class: start-end
}
api: "Spring API\n디코딩 + 저장" {
  class: process
}
disk: "파일 시스템\nuploads/" {
  class: storage
}
db: "H2 DB\n메타데이터" {
  class: storage
}
response: "URL 반환" {
  class: start-end
}

client -> api: "POST /upload" {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
api -> disk: "파일 저장" {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
api -> db: "DB 저장" {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
api -> response: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
