direction: right

classes: {
  step: {
    shape: rectangle
    style: {
      fill: "#ffffff"
      stroke: "#2563eb"
      stroke-width: 2
      border-radius: 8
      shadow: true
      font-size: 20
      font-color: "#374151"
      bold: true
    }
    width: 220
    height: 70
  }
}

step1: "Polling\nAjax 반복 요청" {
  class: step
}
step2: "SSE\n서버 단방향 전송" {
  class: step
}
step3: "WebSocket\nSTOMP 양방향" {
  class: step
}
step4: "세 방식\n비교 정리" {
  class: step
}

step1 -> step2: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
step2 -> step3: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
step3 -> step4: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
