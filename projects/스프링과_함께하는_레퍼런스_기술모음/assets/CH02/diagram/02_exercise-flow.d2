direction: right

classes: {
  step: {
    shape: rectangle
    style: {
      fill: "#ffffff"
      stroke: "#2563eb"
      stroke-width: 2
      border-radius: 8
      shadow: true
      font-size: 20
      font-color: "#374151"
      bold: true
    }
    width: 220
    height: 70
  }
}

step1: "카카오 디벨로퍼\n앱 설정" {
  class: step
}
step2: "SSR\nCode 방식 로그인" {
  class: step
}
step3: "REST API\nCode + OIDC" {
  class: step
}
step4: "JWT\n공개키 검증" {
  class: step
}

step1 -> step2: {
  style: {
    stroke: "#2563eb"
    stroke-width: 2
  }
}
step2 -> step3: {
  style: {
    stroke: "#2563eb"
    stroke-width: 2
  }
}
step3 -> step4: {
  style: {
    stroke: "#2563eb"
    stroke-width: 2
  }
}
