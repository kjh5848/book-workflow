direction: right

classes: {
  step: {
    shape: rectangle
    style: {
      fill: "#ffffff"
      stroke: "#2563eb"
      stroke-width: 2
      border-radius: 8
      shadow: true
      font-size: 20
      font-color: "#374151"
      bold: true
    }
    width: 220
    height: 70
  }
}

step1: "S3 버킷 생성\n+ IAM 설정" {
  class: step
}
step2: "Presigned URL\n발급 구현" {
  class: step
}
step3: "S3 직접 업로드\n테스트" {
  class: step
}
step4: "Lambda\n리사이즈 구현" {
  class: step
}
step5: "DB 메타 저장\n+ 조회 API" {
  class: step
}

step1 -> step2: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
step2 -> step3: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
step3 -> step4: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
step4 -> step5: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
