direction: right

classes: {
  step: {
    shape: rectangle
    style: {
      fill: "#ffffff"
      stroke: "#2563eb"
      stroke-width: 2
      border-radius: 8
      shadow: true
      font-size: 20
      font-color: "#374151"
      bold: true
    }
    width: 220
    height: 70
  }
}

step1: "RabbitMQ\nDocker 실행" {
  class: step
}
step2: "Producer\n폴링 + 발행" {
  class: step
}
step3: "Consumer\n메시지 소비" {
  class: step
}
step4: "통합 테스트\nGitHub → 파일 반영" {
  class: step
  width: 280
}

step1 -> step2: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
step2 -> step3: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
step3 -> step4: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
